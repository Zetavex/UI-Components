{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "dist/types",
    "rootDir": "./src",
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "allowJs": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
